# ═══════════════════════════════════════════════════════════════
# META — WHATSAPP BUSINESS
# ═══════════════════════════════════════════════════════════════
META_WA_PHONE_NUMBER_ID=[phone-number-id]
META_WA_BUSINESS_ACCOUNT_ID=[waba-id]
META_WA_ACCESS_TOKEN=[access-token-permanente]
META_WA_VERIFY_TOKEN=[tu-token-secreto-para-verificar-webhook]
