# ═══════════════════════════════════════════════════════════════
# META — INSTAGRAM DM
# ═══════════════════════════════════════════════════════════════
META_IG_PAGE_ID=[instagram-business-id]
META_IG_ACCESS_TOKEN=[access-token-pagina]

# ═══════════════════════════════════════════════════════════════
# META — MESSENGER
# ═══════════════════════════════════════════════════════════════
META_MESSENGER_PAGE_ID=[facebook-page-id]
META_MESSENGER_ACCESS_TOKEN=[page-access-token]

# ═══════════════════════════════════════════════════════════════
# TELEGRAM BOT
# ═══════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=[token-del-bot]
TELEGRAM_WEBHOOK_SECRET=[secreto-para-validar-webhook]

# ═══════════════════════════════════════════════════════════════
# TWILIO SMS (Fase 3)
# ═══════════════════════════════════════════════════════════════
TWILIO_ACCOUNT_SID=[account-sid]
TWILIO_AUTH_TOKEN=[auth-token]
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ═══════════════════════════════════════════════════════════════
# EMAIL — RESEND (Fase 3)
# ═══════════════════════════════════════════════════════════════
