# ═══════════════════════════════════════════════════════════════
# NOTION (gestión de proyecto)
# ═══════════════════════════════════════════════════════════════
NOTION_API_KEY=secret_...
NOTION_DATABASE_TASKS_ID=[database-id-de-tasks]
NOTION_DATABASE_PROJECTS_ID=[database-id-de-projects]
NOTION_DATABASE_SUBTASKS_ID=[database-id-de-subtasks]

# ═══════════════════════════════════════════════════════════════
# APP (configuración general — público)
# ═══════════════════════════════════════════════════════════════
