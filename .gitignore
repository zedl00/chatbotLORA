# Ruta: /.gitignore

# ── Dependencias ──────────────────────────────────
node_modules/
.pnpm-store/

# ── Variables de entorno ──────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── Builds ────────────────────────────────────────
dist/
dist-ssr/
dist.zip
lora.zip
*.local
.vite/
.turbo/
.DS_Store

# ── Supabase ──────────────────────────────────────
.supabase/
supabase/.temp/
supabase/.branches/

# ── Logs ──────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Archivos de credenciales y secretos ───────────
docs/apikeyantropic
docs/*.key
*.pem
*.secret
credentials.json
secrets.json

# ── 🆕 Fase 4: ZIPs entregados por Claude ─────────
# Los ZIPs son entregables temporales, no código fuente
docs/*.zip
*.zip
!.zip-allowlist/*.zip

# ── Editor / OS ───────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Testing & Coverage ────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/

# ── TypeScript build info ─────────────────────────
*.tsbuildinfo

# ── Misc ──────────────────────────────────────────
.cache/
.temp/
.tmp/