# Ruta: /.gitignore

# ── Dependencias ──────────────────────────────────
node_modules/
.pnpm-store/

# ── Variables de entorno ──────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── Builds ────────────────────────────────────────
dist/
dist-ssr/
*.local
.vite/
.turbo/

# ── Supabase ──────────────────────────────────────
.supabase/
supabase/.temp/
supabase/.branches/

# ── Logs ──────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Editor / OS ───────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Testing & Coverage ────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/

# ── TypeScript build info ─────────────────────────
*.tsbuildinfo

# ── Misc ──────────────────────────────────────────
.cache/
.temp/
.tmp/
